#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/private/tmp/mcp-template-bumps/mcp-resource-watcher/node_modules/.pnpm/@mcp-use+cli@3.2.0_c9c9630bf46ba60bb7b591981f0b21fe/node_modules/@mcp-use/cli/node_modules:/private/tmp/mcp-template-bumps/mcp-resource-watcher/node_modules/.pnpm/@mcp-use+cli@3.2.0_c9c9630bf46ba60bb7b591981f0b21fe/node_modules:/private/tmp/mcp-template-bumps/mcp-resource-watcher/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/private/tmp/mcp-template-bumps/mcp-resource-watcher/node_modules/.pnpm/@mcp-use+cli@3.2.0_c9c9630bf46ba60bb7b591981f0b21fe/node_modules/@mcp-use/cli/node_modules:/private/tmp/mcp-template-bumps/mcp-resource-watcher/node_modules/.pnpm/@mcp-use+cli@3.2.0_c9c9630bf46ba60bb7b591981f0b21fe/node_modules:/private/tmp/mcp-template-bumps/mcp-resource-watcher/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../@mcp-use/cli/dist/index.cjs" "$@"
else
  exec node  "$basedir/../@mcp-use/cli/dist/index.cjs" "$@"
fi
